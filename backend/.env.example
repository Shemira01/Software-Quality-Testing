# Firebase Realtime Database URL
DATABASE_URL=https://your-project-id-default-rtdb.firebaseio.com/

# Firebase legacy database secret, only for local migration/reference.
# Do not commit your real secret.
DATABASE_SECRET=replace-with-your-database-secret

# Path to your local service account key file
# Teammates should rename their key to serviceAccountKey.json
GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json
